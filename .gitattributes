# FxOs — satır sonu normalizasyonu
# Metin dosyaları repoda LF olarak saklanır; checkout'ta platforma bırakılır.
* text=auto

# Açıkça LF olması gerekenler
*.cs        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.sln       text eol=lf

# İkili dosyalar
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
