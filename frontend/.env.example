# FxOs Frontend — ortam değişkenleri örneği
# Bu dosyayı `.env` olarak kopyalayın ve local değerlerinizi girin.

# Frontend'in istek atacağı API kök yolu.
# Dev'de proxy üzerinden gittiği için göreli '/api' önerilir.
VITE_API_BASE_URL=/api

# Dev proxy'nin yönlendireceği local API adresi (vite.config.ts kullanır).
# Backend http launch profile portu (bkz. src/FxOs.API/Properties/launchSettings.json).
VITE_API_PROXY_TARGET=http://localhost:5137
