# FxOs Frontend — ÜRETİM (Vercel) ortam değişkenleri.
# Vite, `npm run build` (production mode) sırasında bu dosyayı otomatik yükler.
# Cross-site cookie auth için API kök yolu absolute https olmalıdır (dev'deki proxy yok).
# İstenirse Vercel proje ayarlarındaki Environment Variables ile de override edilebilir.
VITE_API_BASE_URL=https://fxapi.limanyazilim.com/api
