{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/fxos-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "EnableMSSqlSink": true
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "http://localhost:5176"
    ]
  },
  "Auth": {
    "CookieName": "FxOs.Auth",
    "ExpireDays": 7
  },
  "Seed": {
    "Enabled": true,
    "AdminEmail": "admin@fxos.local",
    "AdminPassword": "",
    "AdminFullName": "FxOs Admin"
  },
  "Storage": {
    "Provider": "local",
    "Local": {
      "RootPath": "App_Data/storage"
    },
    "R2": {
      "ServiceUrl": "",
      "AccessKey": "",
      "SecretKey": "",
      "Bucket": "",
      "PublicBaseUrl": ""
    }
  },
  "AllowedHosts": "*"
}
